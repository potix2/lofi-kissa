# Discord bot token (from Discord Developer Portal)
DISCORD_TOKEN=your_token_here

# Your Discord user ID (right-click yourself → Copy User ID)
# Bot auto-joins when this user enters a voice channel
OWNER_ID=your_discord_user_id_here

# ── Optional: Extra streams (YouTube videos or playlists) ──────────────────────
# Comma-separated list of YouTube URLs to add to the stream pool.
# Playlists are supported — a random track is picked each time.
# EXTRA_STREAMS=https://www.youtube.com/playlist?list=PLxxxxxx,https://www.youtube.com/watch?v=yyyy

# Optional display titles for each EXTRA_STREAMS entry (comma-separated).
# EXTRA_STREAM_TITLES=My Premium Playlist,Favorite Track

# ── Optional: YouTube cookies (for YouTube Premium / age-restricted content) ──
# Path to a cookies.txt file exported from your browser.
# Required to play YouTube Premium playlists or members-only content.
# See .claude/skills/setup/SKILL.md for export instructions.
# COOKIES_FILE=/path/to/cookies.txt
